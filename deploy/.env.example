# ============================================================
#  انسخ هذا الملف إلى .env على الـ VPS واملأ القيم
#  cp deploy/.env.example .env
# ============================================================

NODE_ENV=production

# قاعدة البيانات PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/chouiaar_db

# جلسات المستخدمين — ضع نصاً عشوائياً طويلاً
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# Object Storage (اختياري)
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=
